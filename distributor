<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Pixelwalls — SOL Distributor Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=JetBrains+Mono:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root{--void:#06060c;--deep:#0c0a18;--purple:#2d1b69;--violet:#5b21b6;--lav:#9945FF;--pink:#e879f9;--gold:#fbbf24;--cyan:#22d3ee;--green:#14F195;--white:#e0e0e8;--muted:#78788c;--red:#FF4545;--orange:#ff9945;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--void);color:var(--white);font-family:'JetBrains Mono','Fira Code',monospace;min-height:100vh;}

/* NAV */
.nav{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:52px;background:rgba(10,6,18,.95);border-bottom:1px solid rgba(153,69,255,.2);backdrop-filter:blur(12px);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--gold);font-family:'Press Start 2P',monospace;font-size:9px;letter-spacing:1px;}
.nav-logo-icon{width:28px;height:28px;border-radius:6px;background:linear-gradient(135deg,#9945FF,#14F195);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;color:#000;}
.nav-right{display:flex;gap:8px;align-items:center;}
.nav-btn{background:transparent;border:1px solid rgba(153,69,255,.4);color:var(--lav);font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 14px;cursor:pointer;transition:all .2s;font-weight:600;}
.nav-btn:hover{background:rgba(153,69,255,.15);}
.nav-btn.connected{background:rgba(20,241,149,.1);border-color:rgba(20,241,149,.4);color:var(--green);}
.nav-btn.buy{border-color:var(--gold);color:var(--gold);}

/* GATE */
.gate{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 52px);padding:40px 20px;text-align:center;}
.gate-icon{font-size:64px;margin-bottom:24px;filter:drop-shadow(0 0 30px rgba(153,69,255,.5));}
.gate-title{font-family:'Press Start 2P',monospace;font-size:14px;color:var(--gold);margin-bottom:16px;letter-spacing:2px;}
.gate-msg{font-size:14px;color:var(--muted);max-width:500px;line-height:1.8;margin-bottom:24px;}
.gate-btn{background:linear-gradient(135deg,var(--lav),var(--pink));border:none;color:#fff;font-family:'Press Start 2P',monospace;font-size:8px;padding:14px 28px;cursor:pointer;letter-spacing:1px;transition:all .2s;}
.gate-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(153,69,255,.4);}

/* LAYOUT */
.app{display:flex;height:calc(100vh - 52px);}
.content{flex:1;padding:20px;overflow-y:auto;}
.log-panel{width:320px;border-left:1px solid rgba(153,69,255,.15);background:rgba(0,0,0,.3);display:flex;flex-direction:column;}
.log-header{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.06);font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;display:flex;justify-content:space-between;}
.log-body{flex:1;overflow-y:auto;padding:8px 14px;}
.log-entry{font-size:10px;padding:3px 0;line-height:1.5;}
.log-ts{color:#555;margin-right:6px;}

/* CARDS */
.card{background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:20px;margin-bottom:16px;}
.card-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--lav);margin-bottom:14px;}

/* FEE BANNER */
.fee-banner{background:linear-gradient(135deg,rgba(153,69,255,.1),rgba(20,241,149,.05));border:1px solid rgba(153,69,255,.3);border-radius:10px;padding:20px;margin-bottom:16px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
.fee-total{font-size:24px;font-weight:800;background:linear-gradient(135deg,#9945FF,#14F195);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.fee-alt{font-size:12px;color:var(--muted);margin-top:4px;}
.fee-pay-btn{padding:10px 20px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;transition:all .2s;}
.fee-pay-sol{background:linear-gradient(135deg,#9945FF,#7B3FCC);color:#fff;}
.fee-pay-pixel{background:linear-gradient(135deg,var(--gold),#e6a800);color:#000;}

/* INPUTS */
.inp{width:100%;padding:8px 12px;border-radius:6px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.4);color:var(--white);font-size:12px;font-family:inherit;outline:none;}
.inp:focus{border-color:var(--lav);}
.label{font-size:10px;color:var(--muted);margin-bottom:4px;display:block;text-transform:uppercase;letter-spacing:.06em;}

/* BUTTONS */
.btn{padding:8px 18px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit;transition:all .2s;}
.btn-primary{background:linear-gradient(135deg,#9945FF,#7B3FCC);color:#fff;}
.btn-success{background:linear-gradient(135deg,#14F195,#0DB877);color:#000;}
.btn-danger{background:linear-gradient(135deg,#FF4545,#CC3636);color:#fff;}
.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,.1);color:var(--muted);}
.btn:disabled{opacity:.4;cursor:not-allowed;}
.btn:hover:not(:disabled){filter:brightness(1.15);transform:translateY(-1px);}

/* ROWS */
.row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}

/* STATS */
.stat-box{background:rgba(153,69,255,.06);border-radius:8px;padding:12px 16px;text-align:center;}
.stat-val{font-size:20px;font-weight:800;background:linear-gradient(135deg,#9945FF,#14F195);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.stat-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}

/* WALLET ROW */
.w-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;margin-bottom:4px;background:rgba(255,255,255,.015);border:1px solid rgba(255,255,255,.04);flex-wrap:wrap;}
.w-label{font-weight:700;font-size:12px;min-width:80px;color:var(--lav);}
.w-addr{font-size:11px;color:#b0b0bc;word-break:break-all;}

/* BADGE */
.badge{padding:2px 10px;border-radius:4px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;}
.badge-ready{background:rgba(20,241,149,.15);color:#14F195;}
.badge-funded{background:rgba(20,241,149,.3);color:#14F195;}
.badge-bought{background:rgba(153,69,255,.3);color:#b380ff;}
.badge-sold{background:rgba(255,193,7,.3);color:#ffc107;}
.badge-swept{background:rgba(120,120,140,.3);color:#78788c;}
.badge-error{background:rgba(255,69,69,.3);color:#ff4545;}

/* TABS */
.tabs{display:flex;gap:2px;background:rgba(255,255,255,.03);border-radius:8px;padding:3px;margin-bottom:16px;}
.tab{padding:8px 16px;border-radius:6px;border:none;cursor:pointer;font-size:11px;font-weight:600;font-family:inherit;letter-spacing:.02em;transition:all .2s;background:transparent;color:var(--muted);}
.tab.active{background:linear-gradient(135deg,rgba(153,69,255,.3),rgba(20,241,149,.15));color:var(--green);}

/* TOKEN RESULT */
.token-result{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;cursor:pointer;margin-bottom:4px;background:rgba(255,255,255,.015);border:1px solid rgba(255,255,255,.04);transition:background .15s;}
.token-result:hover{background:rgba(153,69,255,.1);}
.token-result.selected{background:rgba(20,241,149,.08);border-color:rgba(20,241,149,.3);}

/* TABLE */
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{text-align:left;padding:8px 10px;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid rgba(255,255,255,.08);}
.tbl td{padding:10px;border-bottom:1px solid rgba(255,255,255,.03);}

/* TOAST */
.toast{position:fixed;bottom:22px;right:22px;z-index:2000;background:rgba(12,10,24,.97);border:1px solid var(--lav);padding:11px 16px;font-size:11px;max-width:320px;line-height:1.7;transform:translateX(200%);transition:transform .35s ease;}
