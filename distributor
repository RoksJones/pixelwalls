<script>
// ═══════════════════════════════════════════════════════════════════
// PIXELWALLS SOL DISTRIBUTOR — NFT-GATED TOOL
// ═══════════════════════════════════════════════════════════════════

const CA           = '7QaSvPcEpdDNPeMFxp591axQ7cNyca8h1Su79ckzpump';
const PIXEL_MINT   = '7QaSvPcEpdDNPeMFxp591axQ7cNyca8h1Su79ckzpump';
const TREASURY     = '9LABvUXzxnQghFCnjVETzAPBwhFAb4UT2qSVsFvHViHk';
const AGENT_WALLET = 'HKCnYsvPFJAK63mBfoaat7A93K9SUKSjH92G2tMjKawC';
const SOL_MINT     = 'So11111111111111111111111111111111111111112';
const LAMPORTS     = 1_000_000_000;
const FEE_PER_WALLET = 0.005; // SOL
const MAX_WALLETS  = 1000;
const JUP_API      = 'https://quote-api.jup.ag/v6';

let walletConnected = false;
let walletAddress   = null;
let walletObj       = null;
let hasNFT          = false;
let feePaid         = false;
let pixelPrice      = 0; // USD per $PIXEL
let solPrice        = 170;
let subWallets      = [];
let tokenMint       = '';
let tokenInfo       = null;
let currentTab      = 'setup';

// ── WALLET CONNECTION ──────────────────────────────────────────
function getWallets(){
  const w=[];
  if(window.phantom?.solana?.isPhantom) w.push({name:'Phantom',obj:window.phantom.solana});
  else if(window.solana?.isPhantom) w.push({name:'Phantom',obj:window.solana});
  if(window.solflare?.isSolflare) w.push({name:'Solflare',obj:window.solflare});
  if(window.backpack?.isBackpack) w.push({name:'Backpack',obj:window.backpack});
  return w;
}

async function connectWallet(){
  const ws = getWallets();
  if(!ws.length){ showToast('No wallet found — install Phantom'); return; }
  try{
    const w = ws[0];
    const r = await w.obj.connect();
    const pk = r?.publicKey?.toString() || w.obj.publicKey?.toString();
    if(!pk) throw new Error('No public key');
    walletAddress = pk;
    walletConnected = true;
    walletObj = w.obj;
    const short = pk.slice(0,4)+'...'+pk.slice(-4);
    const btn = document.getElementById('walletBtn');
    btn.textContent = '✦ '+short;
    btn.classList.add('connected');
    addLog(`Wallet connected: ${short}`, 'success');
    await checkNFTGate();
  }catch(e){
    showToast(e.code===4001?'Cancelled':e.message);
  }
}

// ── NFT GATE CHECK ─────────────────────────────────────────────
async function checkNFTGate(){
  addLog('Checking Pixelwalls NFT ownership...');
  const gateErr = document.getElementById('gateError');

  try{
    // Check wall-state for any pixel owned by this wallet
    const r = await fetch('/api/wall-state');
    if(!r.ok) throw new Error('Wall-state API unavailable');
    const d = await r.json();
    const short = walletAddress.slice(0,4)+'...'+walletAddress.slice(-4);

    if(d.kvReady && d.pixels){
      const owned = Object.values(d.pixels).filter(p =>
        p.owner === short || p.owner === walletAddress
      );
      if(owned.length > 0){
        hasNFT = true;
        addLog(`✦ NFT verified! You own ${owned.length} pixel(s)`, 'success');
        document.getElementById('gateScreen').style.display = 'none';
        document.getElementById('mainApp').style.display = 'flex';
        renderSetupTab();
        fetchPrices();
        return;
      }
    }

    // Also check via Helius DAS for cNFT ownership (once minting is live)
    // For now, check if wallet owns any $PIXEL tokens as secondary gate
    const tokenCheck = await rpcCall('getTokenAccountsByOwner', [
      walletAddress,
      {mint: PIXEL_MINT},
      {encoding:'jsonParsed'}
    ]);
    const accounts = tokenCheck?.value || [];
    if(accounts.length > 0){
      const bal = accounts[0]?.account?.data?.parsed?.info?.tokenAmount?.uiAmount || 0;
      if(bal >= 10000){ // min 10K $PIXEL to access
        hasNFT = true;
        addLog(`✦ Access granted via ${Math.floor(bal).toLocaleString()} $PIXEL holdings`, 'success');
        document.getElementById('gateScreen').style.display = 'none';
        document.getElementById('mainApp').style.display = 'flex';
        renderSetupTab();
        fetchPrices();
        return;
      }
    }

    // Access denied
    gateErr.style.display = 'block';
    gateErr.textContent = '✕ No Pixelwalls NFT or insufficient $PIXEL found. You need at least 1 pixel or 10,000 $PIXEL.';
    addLog('Access denied — no qualifying NFT or tokens', 'error');

  }catch(e){
    gateErr.style.display = 'block';
    gateErr.textContent = 'Error checking ownership: '+e.message;
    addLog('Gate check error: '+e.message, 'error');
  }
}

// ── RPC HELPER ─────────────────────────────────────────────────
async function rpcCall(method, params=[]){
  const r = await fetch('https://api.mainnet-beta.solana.com', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({jsonrpc:'2.0',id:1,method,params}),
  });
  const d = await r.json();
  if(d.error) throw new Error(d.error.message);
  return d.result;
}

async function getBalance(pubkey){
  const r = await rpcCall('getBalance',[pubkey]);
  return r.value / LAMPORTS;
}

// ── PRICE FETCHING ─────────────────────────────────────────────
async function fetchPrices(){
  try{
    const r = await fetch(`https://api.dexscreener.com/tokens/v1/solana/${CA}`);
    if(!r.ok) return;
    const d = await r.json();
    const arr = Array.isArray(d)?d:(d.pairs||[]);
    if(arr.length){
      const p = arr[0];
      if(p.priceUsd) pixelPrice = parseFloat(p.priceUsd);
      if(p.priceUsd && p.priceNative){
        const derived = parseFloat(p.priceUsd)/parseFloat(p.priceNative);
        if(derived>10 && derived<10000) solPrice = derived;
      }
    }
  }catch(e){}
}

// ── FEE SYSTEM ─────────────────────────────────────────────────
function updateFee(){
  const count = subWallets.length;
  const banner = document.getElementById('feeBanner');
  if(count === 0){ banner.style.display = 'none'; return; }
  banner.style.display = 'flex';

  const totalSOL = (count * FEE_PER_WALLET).toFixed(4);
  document.getElementById('feeTotal').textContent = totalSOL + ' SOL';
  document.getElementById('feeWalletCount').textContent = count;

  // Calculate $PIXEL equivalent
  if(pixelPrice > 0){
    const solValue = count * FEE_PER_WALLET * solPrice;
    const pixelNeeded = Math.ceil(solValue / pixelPrice);
    document.getElementById('feeAlt').textContent = `or ${pixelNeeded.toLocaleString()} $PIXEL`;
  }

  const paySOL = document.getElementById('paySOLBtn');
  const payPIXEL = document.getElementById('payPIXELBtn');
  paySOL.disabled = feePaid;
  payPIXEL.disabled = feePaid;

  if(feePaid){
    document.getElementById('feeStatus').style.display = 'block';
    document.getElementById('feeStatus').textContent = '✦ FEE PAID — TOOL UNLOCKED';
    paySOL.textContent = '✓ PAID';
    payPIXEL.textContent = '✓ PAID';
  }
}

async function payFee(method){
  if(!walletConnected){ showToast('Connect wallet first'); return; }
  const count = subWallets.length;
  if(count === 0){ showToast('Generate wallets first'); return; }

  const totalSOL = count * FEE_PER_WALLET;
  addLog(`Initiating ${method.toUpperCase()} payment for ${count} wallets...`);

  try{
    // We need @solana/web3.js loaded
    // For now, build a simple SOL transfer
    if(method === 'sol'){
      showToast(`⚡ Approve ${totalSOL} SOL payment in wallet...`);
      // Build SOL transfer to treasury
      addLog(`Sending ${totalSOL} SOL to treasury...`);
      // The actual transfer would use wallet adapter
      // For now mark as paid after confirmation
      feePaid = true;
      updateFee();
      addLog(`✦ Fee paid: ${totalSOL} SOL → treasury`, 'success');
      showToast('✦ Fee paid! Tool unlocked.');

    } else if(method === 'pixel'){
      const solValue = totalSOL * solPrice;
      const pixelNeeded = Math.ceil(solValue / pixelPrice);
      showToast(`⚡ Approve ${pixelNeeded.toLocaleString()} $PIXEL payment...`);
      addLog(`Sending ${pixelNeeded.toLocaleString()} $PIXEL to staking pool...`);
      feePaid = true;
      updateFee();
      addLog(`✦ Fee paid: ${pixelNeeded.toLocaleString()} $PIXEL → staking pool`, 'success');
      showToast('✦ Fee paid! Tool unlocked.');
    }
  }catch(e){
    addLog('Payment error: '+e.message, 'error');
    showToast('Payment failed: '+e.message);
  }
}

// ── BASE58 ─────────────────────────────────────────────────────
const B58='123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz';
function b58encode(bytes){
  const d=[0];
  for(let i=0;i<bytes.length;i++){let c=bytes[i];for(let j=0;j<d.length;j++){c+=d[j]<<8;d[j]=c%58;c=(c/58)|0;}while(c){d.push(c%58);c=(c/58)|0;}}
  let s='';for(let i=0;i<bytes.length&&bytes[i]===0;i++)s+='1';
  for(let i=d.length-1;i>=0;i--)s+=B58[d[i]];return s;
}

// ── WALLET GENERATION ──────────────────────────────────────────
async function generateKeypair(){
  try{
    const kp=await crypto.subtle.generateKey('Ed25519',true,['sign','verify']);
    const pub=new Uint8Array(await crypto.subtle.exportKey('raw',kp.publicKey));
    const priv=new Uint8Array(await crypto.subtle.exportKey('pkcs8',kp.privateKey));
    const seed=priv.slice(16,48);
    const sk=new Uint8Array(64);sk.set(seed,0);sk.set(pub,32);
    return{publicKey:b58encode(pub),secretKey:b58encode(sk),seedHex:Array.from(seed).map(b=>b.toString(16).padStart(2,'0')).join('')};
  }catch{
    const seed=new Uint8Array(32);crypto.getRandomValues(seed);
    const mock=new Uint8Array(32);crypto.getRandomValues(mock);
    return{publicKey:b58encode(mock),secretKey:b58encode(new Uint8Array([...seed,...mock])),seedHex:Array.from(seed).map(b=>b.toString(16).padStart(2,'0')).join(''),note:'Ed25519 unavailable'};
  }
}

async function generateWallets(count){
  if(count < 1 || count > MAX_WALLETS){ showToast(`Max ${MAX_WALLETS} wallets`); return; }
  addLog(`Generating ${count} wallets...`);
  for(let i=0;i<count;i++){
    const kp = await generateKeypair();
    subWallets.push({
      id: Date.now()+i,
      label: `Wallet-${String(subWallets.length+1).padStart(3,'0')}`,
      publicKey: kp.publicKey,
      secretKey: kp.secretKey,
      seedHex: kp.seedHex,
      solBalance: 0,
      tokenBalance: 0,
      status: 'ready',
    });
    addLog(`  ✓ ${kp.publicKey.slice(0,8)}...${kp.publicKey.slice(-4)}`);
  }
  addLog(`${count} wallets generated`, 'success');
  updateFee();
  renderWalletsTab();
}

async function refreshBalances(){
  addLog('Refreshing balances...');
  for(let i=0;i<subWallets.length;i++){
    try{
      subWallets[i].solBalance = await getBalance(subWallets[i].publicKey);
    }catch(e){ addLog(`Error: ${subWallets[i].label}: ${e.message}`, 'error'); }
  }
  addLog('Balances refreshed', 'success');
  renderWalletsTab();
}

// ── JUPITER ────────────────────────────────────────────────────
async function jupiterQuote(inputMint, outputMint, amount, slippageBps){
  const url = `${JUP_API}/quote?inputMint=${inputMint}&outputMint=${outputMint}&amount=${amount}&slippageBps=${slippageBps}`;
  const r = await fetch(url);
  if(!r.ok) throw new Error('Jupiter quote failed');
  return r.json();
}

async function executeBuy(idx){
  const w = subWallets[idx];
  const buySOL = parseFloat(document.getElementById('buyAmount')?.value || '0.01');
  const slip = parseFloat(document.getElementById('slippage')?.value || '1');
  if(!tokenMint){ showToast('Select a token first'); return; }
  addLog(`[BUY] Getting quote for ${w.label}...`);
  try{
    const quote = await jupiterQuote(SOL_MINT, tokenMint, Math.floor(buySOL*LAMPORTS), slip*100);
    const decimals = tokenInfo?.decimals || 6;
    addLog(`Quote: ~${(quote.outAmount/Math.pow(10,decimals)).toLocaleString()} ${tokenInfo?.symbol||'tokens'}`);
    subWallets[idx].status = 'bought';
    addLog(`TX created for ${w.label}. Sign with private key.`, 'success');
  }catch(e){ addLog(`Buy error: ${e.message}`, 'error'); }
  renderBuyTab();
}

async function executeSell(idx){
  const w = subWallets[idx];
  const slip = parseFloat(document.getElementById('slippage')?.value || '1');
  addLog(`[SELL] ${w.label}...`);
  try{
    if(!w.tokenBalance || w.tokenBalance === 0){ addLog('No tokens to sell','error'); return; }
    const rawAmt = Math.floor(w.tokenBalance * Math.pow(10, tokenInfo?.decimals||6));
    const quote = await jupiterQuote(tokenMint, SOL_MINT, rawAmt, slip*100);
    addLog(`Sell quote: ~${(quote.outAmount/LAMPORTS).toFixed(4)} SOL`, 'success');
    subWallets[idx].status = 'sold';
  }catch(e){ addLog(`Sell error: ${e.message}`, 'error'); }
  renderSellTab();
}

// ── TOKEN SEARCH ───────────────────────────────────────────────
async function searchToken(){
  const q = document.getElementById('tokenSearch')?.value?.trim();
  if(!q) return;
  addLog(`Searching: ${q}`);
  try{
    const r = await fetch(`https://tokens.jup.ag/tokens/v1/search?query=${encodeURIComponent(q)}&limit=8`);
    const data = await r.json();
    renderSearchResults(data||[]);
    addLog(`Found ${(data||[]).length} tokens`, 'success');
  }catch(e){
    addLog(`Search error: ${e.message}`, 'error');
  }
}

function selectToken(t){
  tokenMint = t.address || t.mint;
  tokenInfo = t;
  addLog(`Selected: ${t.symbol} (${t.name})`);
  renderSetupTab();
}

// ── EXPORT/IMPORT ──────────────────────────────────────────────
function exportWallets(){
  const data = subWallets.map(w=>({label:w.label,publicKey:w.publicKey,secretKey:w.secretKey,seedHex:w.seedHex,status:w.status}));
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download=`sol-wallets-${Date.now()}.json`; a.click();
  URL.revokeObjectURL(url);
  addLog('Wallets exported', 'success');
}

function importWallets(e){
  const file = e.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try{
      const data = JSON.parse(ev.target.result);
      data.forEach((w,i) => {
        subWallets.push({id:Date.now()+i,label:w.label||`Import-${i}`,publicKey:w.publicKey,secretKey:w.secretKey,seedHex:w.seedHex||'',solBalance:0,tokenBalance:0,status:w.status||'ready'});
      });
      addLog(`Imported ${data.length} wallets`, 'success');
      updateFee();
      renderWalletsTab();
    }catch(err){ addLog(`Import error: ${err.message}`, 'error'); }
  };
  reader.readAsText(file);
}

// ── TAB SWITCHING ──────────────────────────────────────────────
function switchAppTab(name, btn){
  currentTab = name;
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  ['setup','wallets','buy','sell','manage'].forEach(t=>{
    const panel = document.getElementById('panel-'+t);
    if(panel) panel.style.display = t===name ? 'block' : 'none';
  });
  // Re-render active panel
  if(name==='setup')   renderSetupTab();
  if(name==='wallets') renderWalletsTab();
  if(name==='buy')     renderBuyTab();
  if(name==='sell')    renderSellTab();
  if(name==='manage')  renderManageTab();
}

