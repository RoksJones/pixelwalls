{
  "functions": {
    "api/xlogin.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/xcallback.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/metadata.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/pixel-image.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/cluster-metadata.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/mint-cnft.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/update-cnft-metadata.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/counter.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/counter",
      "destination": "/api/counter"
    },
    {
      "source": "/pixelcraft.html",
      "destination": "/pixelcraft.html"
    },
    {
      "source": "/profile.html",
      "destination": "/profile.html"
    },
    {
      "source": "/profile/:col/:row",
      "destination": "/profile.html"
    },
    {
      "source": "/marketplace.html",
      "destination": "/marketplace.html"
    },
    {
      "source": "/tokenomics.html",
      "destination": "/tokenomics.html"
    },
    {
      "source": "/whitepaper.html",
      "destination": "/whitepaper.html"
    },
    {
      "source": "/api/metadata/:col/:row",
      "destination": "/api/metadata"
    },
    {
      "source": "/api/pixel-image/:col/:row",
      "destination": "/api/pixel-image"
    },
    {
      "source": "/api/metadata/cluster/:c1/:r1/:c2/:r2",
      "destination": "/api/cluster-metadata"
    },
    {
      "source": "/api/auth/twitter/callback",
      "destination": "/api/xcallback"
    },
    {
      "source": "/api/auth/twitter/login",
      "destination": "/api/xlogin"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/)[^.]*)",
      "destination": "/index.html"
    }
  ]
}
